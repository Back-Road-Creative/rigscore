node_modules/
coverage/
.DS_Store
*.log

# Local working data — audit reports, plans, health reports, and wave
# PR/commit scratch. Never commit to this public repo: prior contents leaked
# private workflow strings and third-party tool mentions (removed 2026-07-18).
.data/

# Local environment files at repo root — never commit. Anchored with a
# leading `/` so the pattern does NOT cascade to `test/fixtures/**/.env`,
# which are intentional fixtures the env-exposure check needs to see as
# not-ignored (`git check-ignore` walks parent .gitignore chains, so an
# unanchored `.env` here would shadow the fixture).
/.env
/.env.*
!/.env.example

# Dogfood fixture artifacts.
# Scanning any fixture that ships a `.mcp.json` writes a first-scan TOFU pin into
# it (see docs/checks/mcp-config.md), so ignore the strays. Tracked pins — the
# verify-state-* fixtures — are unaffected; a NEW tracked one needs `git add -f`.
test/fixtures/**/.rigscore-state.json
test/fixtures/scored-project/a-plain-file.txt
test/fixtures/scored-project/.claude/skills/test-file.md
test/fixtures/_fixture-home-*/
