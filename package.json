{
  "name": "rigscore",
  "version": "2.2.0",
  "description": "Configuration hygiene checker for AI dev environments. Scans locally, no external calls.",
  "type": "module",
  "bin": {
    "rigscore": "bin/rigscore.js"
  },
  "files": [
    "bin/",
    "src/",
    "templates/",
    "docs/checks/",
    "README.md"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:fixture": "vitest run test/fixture-dogfood.test.js",
    "verify:docs": "node scripts/verify-docs.js",
    "facts": "node scripts/generate-facts.js",
    "changelog": "node scripts/assemble-changelog.js",
    "prepare": "husky || true"
  },
  "engines": {
    "node": ">=18.17.0"
  },
  "keywords": [
    "ai",
    "hygiene",
    "claude",
    "mcp",
    "checker",
    "linter",
    "devtools"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Back-Road-Creative/rigscore.git"
  },
  "dependencies": {
    "chalk": "5.6.2",
    "yaml": "2.9.0"
  },
  "devDependencies": {
    "@cyclonedx/cyclonedx-library": "^10.1.0",
    "@vitest/coverage-v8": "3.2.4",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "ajv-formats-draft2019": "^1.6.1",
    "husky": "^9.1.7",
    "vitest": "3.2.4"
  }
}
